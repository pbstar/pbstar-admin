{
  "name": "pbstar-admin",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "main"
  ],
  "scripts": {
    "create": "node ./cli/index.js",
    "dev": "echo \"Error: 请选择启动模块\" && exit 1",
    "build": "echo \"Error: 请选择构建模块\" && exit 1",
    "deploy": "echo \"Error: 请选择部署模块\" && exit 1",
    "dev:main": "npm run dev --workspace=main",
    "build:main": "npm run build --workspace=main",
    "deploy:main": "npm run build --workspace=main && node ./deploy/main.js",
    "dev:template": "npm run dev --workspace=template",
    "build:template": "npm run build --workspace=template"
  },
  "dependencies": {
    "@micro-zoe/micro-app": "^1.0.0-rc.13",
    "es-toolkit": "^1.27.0",
    "inquirer": "^12.1.0",
    "tdesign-vue-next": "^1.10.3"
  },
  "devDependencies": {
    "sass-embedded": "^1.80.7"
  }
}