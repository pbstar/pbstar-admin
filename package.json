{
  "name": "pbstar-admin",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "create": "node ./cli/index.js",
    "dev": "echo \"Error: 请选择启动模块\" && exit 1",
    "build": "echo \"Error: 请选择构建模块\" && exit 1",
    "deploy": "echo \"Error: 请选择部署模块\" && exit 1",
    "dev:main": "pnpm run -filter main dev",
    "build:main": "pnpm run -filter main build",
    "deploy:main": "pnpm run -filter main build && node ./deploy/main.js",
    "dev:template": "pnpm run -filter template dev",
    "build:template": "pnpm run -filter template build"
  },
  "dependencies": {
    "@micro-zoe/micro-app": "^1.0.0-rc.13",
    "es-toolkit": "^1.27.0",
    "inquirer": "^12.1.0",
    "tdesign-vue-next": "^1.10.3"
  },
  "devDependencies": {
    "sass-embedded": "^1.80.7"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}